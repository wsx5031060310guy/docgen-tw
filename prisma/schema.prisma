generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel + Neon integration injects DATABASE_POSTGRES_PRISMA_URL (pooled,
  // for app queries) and DATABASE_URL_UNPOOLED (direct, for migrations).
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Contract {
  id                     String    @id @default(cuid())
  templateId             String?
  values                 Json?
  client                 String
  content                String
  signatureUrl           String?
  senderSignedAt         DateTime?
  senderSignatureHash    String?
  senderIp               String?
  recipientName          String?
  recipientEmail         String?
  recipientSignatureUrl  String?
  recipientSignedAt      DateTime?
  recipientSignatureHash String?
  recipientIp            String?
  signingToken           String?   @unique
  signingStatus          String    @default("UNSIGNED")
  // Lifecycle: UNSIGNED -> SENDER_SIGNED -> AWAITING_RECIPIENT -> FULLY_SIGNED
  contractPdfUrl         String?
  effectiveDate          DateTime?
  expiryDate             DateTime?
  uid                    String?
  caseId                 String?
  case                   Case?       @relation(fields: [caseId], references: [id])
  milestones             Milestone[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  orders                 Order[]
}

model Case {
  id           String           @id @default(cuid())
  title        String
  clientName   String?
  counterparty String?
  notes        String?
  status       String           @default("OPEN")
  ownerEmail   String?
  contracts    Contract[]
  attachments  CaseAttachment[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model CaseAttachment {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filename  String
  blobUrl   String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
}

model Milestone {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  kind        String
  title       String
  amount      Int?
  dueDate     DateTime
  status      String    @default("PENDING")
  doneAt      DateTime?
  note        String?
  remindedD7  Boolean   @default(false)
  remindedD1  Boolean   @default(false)
  remindedD0  Boolean   @default(false)
  remindedD1p Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SharedCheck {
  id        String   @id
  text      String
  summary   Json
  findings  Json
  llmReason String?
  views     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LawyerReferral {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  city          String?
  topic         String?
  budget        String?
  description   String
  contractId    String?
  status        String   @default("NEW")
  internalNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String    @id @default(cuid())
  merchantTradeNo String    @unique
  contractId      String?
  contract        Contract? @relation(fields: [contractId], references: [id])
  provider        String
  amount          Int
  currency        String    @default("TWD")
  itemName        String
  planCode        String?
  uid             String?
  buyerEmail      String?
  status          String    @default("PENDING")
  paymentMethod   String?
  paymentDate     DateTime?
  rawCallback     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BillingProfile {
  uid        String    @id
  email      String?
  plan       String    @default("FREE")
  periodEnd  DateTime?
  lastOrderId String?
  // User-configurable generic webhook URL (Slack/Discord/Make/n8n/Zapier all
  // accept POST JSON). Single column keeps the model simple; we don't need
  // per-platform parsing here.
  webhookUrl   String?
  webhookSecret String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  uid        String
  // sha256 hex digest of the raw key. We never store the plaintext key.
  hashedKey  String    @unique
  prefix     String    // first 8 chars of the raw key, shown as 'dk_xxxxxxxx…' to the owner
  label      String?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  @@index([uid])
}

model MagicLink {
  id        String    @id @default(cuid())
  email     String
  uid       String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([email])
}

model WebhookDelivery {
  id           String    @id @default(cuid())
  uid          String
  event        String
  url          String
  payload      String?   // serialised JSON body, kept for retries
  secret       String?   // copied at dispatch time so retries don't break if user rotates
  status       Int?
  ok           Boolean
  durationMs   Int
  reason       String?
  attempt      Int       @default(1)
  nextRetryAt  DateTime?
  giveUpAt     DateTime?
  succeeded    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([uid])
  @@index([createdAt])
  @@index([nextRetryAt, succeeded])
}

model Usage {
  id        String   @id @default(cuid())
  uid       String
  month     String   // YYYY-MM, Asia/Taipei
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  @@unique([uid, month])
  @@index([month])
}
